# CuriosityEngine environment variables
#
# Copy this file to .env for local development. Never commit .env.
# Secrets (Discord credentials, GitHub PAT) are NOT listed here:
# they live in Google Cloud Secret Manager and are fetched at runtime.
#
# When running locally you need application-default credentials:
#   gcloud auth application-default login

# GCP project that hosts Firestore, Vertex AI, and Secret Manager.
# On Cloud Run this is inferred from the metadata server when left empty.
GCP_PROJECT=your-gcp-project-id

# Vertex AI region. us-central1 has the widest Gemini model availability.
VERTEX_LOCATION=us-central1

# Firestore database id. Use "(default)" unless you created a named database.
FIRESTORE_DATABASE=(default)

# Gemini model used for daily problem research.
# gemini-2.5-flash balances quality and cost for this workload.
GEMINI_MODEL=gemini-2.5-flash

# Email of the Cloud Scheduler service account whose OIDC token the
# /cron/daily handler validates. Must match the SA configured in Cloud Scheduler.
SCHEDULER_SA_EMAIL=curiosity-scheduler@your-gcp-project-id.iam.gserviceaccount.com

# OIDC audience the scheduler token must carry. Set this to the public URL of
# the Cloud Run service, e.g. https://curiosity-engine-<hash>-uc.a.run.app
EXPECTED_AUDIENCE=https://curiosity-engine-xxxxxxxxxxxx-uc.a.run.app

# GitHub repository the self-maintaining agent opens PRs against.
GITHUB_OWNER=dmjone
GITHUB_REPO=curiosity-engine
GITHUB_DEFAULT_BRANCH=main

# HTTP port the service listens on. Cloud Run injects PORT automatically.
PORT=8080
